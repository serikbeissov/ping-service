# Учётные данные администратора (создаётся при первом запуске, если БД пустая)
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Секрет для подписи сессионных cookie. Сгенерируйте: openssl rand -hex 32
SECRET_KEY=please-change-me-to-a-long-random-string

# Параметры приложения
APP_TITLE=Мониторинг устройств
# Интервал опроса по умолчанию (сек) — можно менять в настройках админки
DEFAULT_INTERVAL=30

# Telegram (опционально — можно задать позже в админке)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
